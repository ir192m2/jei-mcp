{
  "name": "jei-mcp-server",
  "version": "1.0.0",
  "description": "MCP server bridging KiloCode to JEI (Just Enough Items) via an in-game mod",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "graph:import": "node src/graph/import.js",
    "graph:query": "node src/graph/query.js",
    "graph:fetch": "node dist/fetch-graph.js",
    "test:fuzz": "node ../test/fuzz/master.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  },
  "kilocode": {
    "mcpServer": {
      "command": "node",
      "args": ["dist/index.js"]
    }
  }
}
